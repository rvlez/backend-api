generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  COORDINADOR
  DIGITADOR
  MESA
}

enum EstadoSeguimiento {
  APOYA
  INDECISO
  NO_APOYA
  SIN_CONTACTAR
}

enum NivelConfianza {
  ALTO
  MEDIO
  BAJO
}

model Usuario {
  id          Int    @id @default(autoincrement())
  nombre      String
  email       String @unique
  password    String
  rol         Rol
  estado      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seguimientos Seguimiento[]
  actas        Acta[]
}

model Campania {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  fechaInicio DateTime
  fechaFin    DateTime
  esActiva    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidatos   Candidato[]
  seguimientos Seguimiento[]
  actas        Acta[]
}

model Candidato {
  id          Int    @id @default(autoincrement())
  nombre      String
  partido     String
  esPrincipal Boolean @default(false)
  campaniaId  Int
  campania    Campania @relation(fields: [campaniaId], references: [id])

  seguimientos Seguimiento[]
  detallesActa DetalleActa[]
}

model Territorio {
  id       Int    @id @default(autoincrement())
  nombre   String
  tipo     String
  parentId Int?
  parent   Territorio? @relation("TerritorioJerarquia", fields: [parentId], references: [id])
  children Territorio[] @relation("TerritorioJerarquia")

  ciudadanos Ciudadano[]
  mesas      Mesa[]
}

model Ciudadano {
  id         Int    @id @default(autoincrement())
  dni        String @unique
  nombres    String
  apellidos  String
  celular    String?
  direccion  String?
  sectorId   Int?
  sector     Territorio? @relation(fields: [sectorId], references: [id])
  mesaId     Int?
  mesa       Mesa? @relation(fields: [mesaId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  seguimientos Seguimiento[]
}

model Seguimiento {
  id             Int @id @default(autoincrement())
  ciudadanoId    Int
  ciudadano      Ciudadano @relation(fields: [ciudadanoId], references: [id])
  campaniaId     Int
  campania       Campania @relation(fields: [campaniaId], references: [id])
  candidatoId    Int?
  candidato      Candidato? @relation(fields: [candidatoId], references: [id])
  estado         EstadoSeguimiento @default(SIN_CONTACTAR)
  nivelConfianza NivelConfianza?
  observacion    String?
  usuarioId      Int
  usuario        Usuario @relation(fields: [usuarioId], references: [id])
  fechaContacto  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([ciudadanoId, campaniaId])
}

model Mesa {
  id             Int    @id @default(autoincrement())
  codigo         String @unique
  numero         Int
  territorioId   Int
  territorio     Territorio @relation(fields: [territorioId], references: [id])
  totalElectores Int    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ciudadanos Ciudadano[]
  actas      Acta[]
}

model Acta {
  id            Int @id @default(autoincrement())
  mesaId        Int
  mesa          Mesa @relation(fields: [mesaId], references: [id])
  campaniaId    Int
  campania      Campania @relation(fields: [campaniaId], references: [id])
  usuarioId     Int
  usuario       Usuario @relation(fields: [usuarioId], references: [id])
  totalVotos    Int
  imagenActa    String?
  estado        String @default("BORRADOR")
  observacion   String?
  fechaRegistro DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  detalles DetalleActa[]
}

model DetalleActa {
  id          Int @id @default(autoincrement())
  actaId      Int
  acta        Acta @relation(fields: [actaId], references: [id])
  tipo        String
  candidatoId Int?
  candidato   Candidato? @relation(fields: [candidatoId], references: [id])
  cantidad    Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}